        <mxCell id="pde4" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="1" source="pd4" target="pd5"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="note" value="Skewed wavefront (identical to the reference mini-TPU): line i streams during t ∈ [i+1, i+3]; PE[i][c] multiplies A-pair j with W-byte j at t = i+c+1+j. One pair step = one dense step of the reference ⇒ K=6 in the time dense does K=3 (2x throughput). RUN completes at t = 7." style="text;html=1;whiteSpace=wrap;fontSize=11;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
